# =============================================================================
# Cortex — Environment Variables
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# --- Database (PostgreSQL) ---
# Para desenvolvimento local com Docker:
#   docker run -d --name cortex-dev-db -e POSTGRES_DB=cortex_dev -e POSTGRES_USER=cortex -e POSTGRES_PASSWORD=dev123 -p 5432:5432 -v cortex_pgdata:/var/lib/postgresql/data postgres:16
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cortex_dev
DB_USER=cortex
DB_PASSWORD=dev123
DB_SSL=false

# --- Session ---
SESSION_SECRET=gere-um-secret-aleatorio-com-openssl-rand-hex-32

# --- Google OAuth (Data Central, consent screen Internal — só @turbopartners) ---
GOOGLE_CLIENT_ID=seu-google-client-id
GOOGLE_CLIENT_SECRET=seu-google-client-secret

# --- YouTube OAuth (client DEDICADO, projeto GCP próprio, consent screen External) ---
# Permite que donos de canal externos (sem e-mail @turbopartners) autorizem com a conta
# deles. Se vazio, o fluxo do YouTube cai no GOOGLE_CLIENT_ID acima (Internal).
# Redirect URI a cadastrar no client: https://cortex.turbopartners.com.br/api/oauth/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- App URL ---
# Usado para callbacks do OAuth e links em emails
CUSTOM_DOMAIN=localhost:3000
APP_URL=http://localhost:3000

# --- AI APIs (opcionais para dev) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# --- Meta Ads (opcional para dev) ---
META_ADS_ACCESS_TOKEN=
META_ADS_APP_ID=
META_ADS_APP_SECRET=

# --- Meta Ads — Criação de Campanhas (feature subir nova campanha) ---
# Conta de anúncio padrão para onde TODAS as campanhas criadas via UI vão.
# Formato: act_<id> ou apenas <id> (o prefixo "act_" é adicionado automaticamente).
META_DEFAULT_AD_ACCOUNT_ID=
# Page ID que será usada no object_story_spec dos anúncios (Facebook Page).
META_DEFAULT_PAGE_ID=
# Pixel ID — obrigatório se objetivo for Leads ou Vendas.
META_DEFAULT_PIXEL_ID=
# Instagram Actor ID — opcional, se quiser publicar também no Instagram.
META_DEFAULT_INSTAGRAM_ACTOR_ID=

# --- Assinafy (opcional para dev) ---
ASSINAFY_API_KEY=
ASSINAFY_API_URL=

# --- Evolution / TurboZap (opcional para dev) ---
EVOLUTION_SERVER_URL=
EVOLUTION_INSTANCE_ID=
EVOLUTION_TOKEN=

# --- TurboDash (opcional para dev) ---
TURBODASH_API_URL=https://app.turbodash.com.br
INTERNAL_API_TOKEN=

# --- Portal do Cliente ---
CLIENT_DEFAULT_PASSWORD=

# --- Dev mode ---
ENABLE_DEV_LOGIN=true
NODE_ENV=development

# SendGrid — envio de notificações extrajudiciais
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=juridico@turbopartners.com.br
SENDGRID_FROM_NAME=Departamento Jurídico - Turbo Partners
SENDGRID_BCC_EMAIL=juridico@turbopartners.com.br

# Linktree → GA4 (Property ID numérico, não Measurement ID)
# Usado para puxar cliques no link da bio em /api/growth/orcado-realizado/instagram.
# A Service Account em GOOGLE_SERVICE_ACCOUNT_JSON precisa ter Viewer nessa propriedade.
LINKTREE_GA4_PROPERTY_ID=296920973
