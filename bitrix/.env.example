# Template de variaveis de ambiente — copie para .env e preencha os valores.
# O .env real NUNCA deve ser commitado (ver .gitignore).

# --- Bitrix24 CRM ---
# Webhook de entrada (contem token secreto). Mantenha a barra final.
BITRIX_WEBHOOK_URL=https://SEU_DOMINIO.bitrix24.com.br/rest/<user_id>/<token>/

# --- Banco de producao (GCP Cloud SQL) ---
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- Supabase ---
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=
