# ============================================================
# Automação Instagram — Credenciais (copie para .env)
# NUNCA commitar .env (já no .gitignore)
# ============================================================

# ---------- ClickUp ----------
# Settings pessoal → Apps → Generate API Token
CLICKUP_API_TOKEN=pk_
CLICKUP_WORKSPACE_ID=31021986
CLICKUP_LIST_ID_INSTAGRAM=901300920768

# ---------- Google Drive / Docs ----------
# Service Account JSON (Google Cloud Console → IAM → Service Accounts → Keys)
# Caminho absoluto pro arquivo .json baixado. As pastas/Docs do Drive precisam
# estar compartilhados com o client_email da service account (role: Viewer).
GOOGLE_SERVICE_ACCOUNT_JSON=/caminho/absoluto/para/service-account.json

# Raiz fixa do Drive onde vivem as pastas "MM - Mês" (descoberto empiricamente)
GOOGLE_DRIVE_MESES_ROOT_FOLDER_ID=1yGxKCORxe7PipuYKY1yd508IWQyKgIIt

# (Os Docs mensais são descobertos dinamicamente por título "SOCIAL MEDIA TURBO [MÊS]")

# ---------- Re-host de mídia (Drive → GCS → signed URL pra Meta) ----------
# Bucket GCS PRIVADO onde a mídia é re-hospedada temporariamente. A Meta não
# baixa do Drive (cai em login); o agente sobe os bytes aqui e gera uma V4
# signed URL (expira em ~1h). Criado uma vez por um admin do projeto GCP, com
# roles/storage.objectAdmin pra service account NESSE bucket. Ver agente/rehost.py.
GCS_REHOST_BUCKET=turbo-ig-rehost

# ---------- Meta / Instagram ----------
# https://developers.facebook.com → app Business → Instagram Graph API
META_APP_ID=
META_APP_SECRET=
# Long-Lived Token (60 dias — renovar via cron)
META_LONG_LIVED_TOKEN=
META_PAGE_ID=
IG_BUSINESS_ACCOUNT_ID=

# ---------- TikTok (Content Posting API) ----------
# App em developers.tiktok.com → produto "Content Posting API".
# Scopes: user.info.basic, video.upload (rascunho), video.publish (direct/auditado).
# A REDIRECT_URI precisa estar registrada no app (HTTPS). Os tokens (access/refresh)
# são obtidos via OAuth e ficam em .cache/tiktok_tokens.json (não no .env).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
# --- Orquestrador TikTok (agente/main_tiktok.py) ---
# Lista do TikTok no ClickUp (separada da do Instagram).
CLICKUP_LIST_ID_TIKTOK=
# draft = rascunho/inbox (sem auditoria, legenda manual) | direct = publica direto
# (precisa auditoria p/ público; app não auditado só posta SELF_ONLY).
TIKTOK_POST_MODE=draft
# Só p/ direct: SELF_ONLY | PUBLIC_TO_EVERYONE | MUTUAL_FOLLOW_FRIENDS
TIKTOK_PRIVACY_LEVEL=SELF_ONLY

# ---------- Anthropic (fallback pra gerar legenda quando Doc está vazio) ----------
ANTHROPIC_API_KEY=sk-ant-
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------- Operação ----------
# DRY_RUN=1 → agente lê tudo mas não chama Meta e não escreve no ClickUp
# DRY_RUN=0 → modo produção
DRY_RUN=1

# Quanto tempo esperar entre ciclos de polling (segundos)
POLL_INTERVAL_SECONDS=300

# ---------- Painel "Orgânico" no Cortex (telemetria do ciclo) ----------
# Opcional: o worker faz POST do estado de cada ciclo pro Cortex, que escreve nas
# tabelas content_*. Se ficar vazio, o agente roda normal e só não atualiza o painel.
# URL do endpoint de ingest (prod: https://<cortex>/api/growth/organico/ingest)
CORTEX_INGEST_URL=
# Token compartilhado — MESMO valor no .env do Cortex (var ORGANICO_INGEST_TOKEN)
ORGANICO_INGEST_TOKEN=
